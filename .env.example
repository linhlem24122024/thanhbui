# Sao chép file này thành .env.local rồi điền giá trị thật.
# .env.local KHÔNG được commit lên git (đã có trong .gitignore) — RULE-01.

# ── Supabase ─────────────────────────────────────────────
# Project Settings > API trong Supabase Dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Xác thực (JWT session cho member + admin) ───────────
# Chuỗi ngẫu nhiên dài, giữ bí mật. Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ── Tài khoản admin (trang /admin) ──────────────────────
ADMIN_EMAIL=
# Hash bcrypt của mật khẩu admin — KHÔNG lưu mật khẩu dạng thường ở đây (RULE-07).
# Tạo bằng: node -e "console.log(require('bcryptjs').hashSync('mat-khau-that', 12))"
ADMIN_PASSWORD_HASH=

# ── Upstash Redis (rate limiting — RULE-08/09) ──────────
# Tạo free database tại https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resend (email thông báo đăng ký mới) ────────────────
# https://resend.com/ — free tier
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMIN_NOTIFY_EMAIL=

# ── Sepay Payment Gateway (cọc nâng cấp gói) ────────────
# my.sepay.vn/pg/merchant > Thông tin đơn vị
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
